# CoachAI 环境配置文件示例
# 复制此文件为 .env 并根据需要修改

# ====================== 应用基础配置 ======================
APP_ENV=development                    # 环境: development, staging, production
APP_DEBUG=true                         # 调试模式
APP_PORT=8888                          # 应用端口
APP_HOST=0.0.0.0                       # 绑定地址
APP_SECRET_KEY=dev-secret-key-change-in-production

# ====================== 数据库配置 ======================
DB_HOST=localhost                      # 数据库主机
DB_PORT=3306                           # 数据库端口
DB_NAME=coach_ai                       # 数据库名称
DB_USER=coach_ai_user                  # 数据库用户
DB_PASSWORD=coach_ai_password          # 数据库密码
DB_CHARSET=utf8mb4                     # 数据库字符集

# SQLAlchemy连接池配置
DB_POOL_SIZE=10                        # 连接池大小
DB_MAX_OVERFLOW=20                     # 最大溢出连接数
DB_POOL_RECYCLE=3600                   # 连接回收时间（秒）
DB_POOL_PRE_PING=true                  # 连接预检

# ====================== Redis配置 ======================
REDIS_HOST=localhost                   # Redis主机
REDIS_PORT=6379                        # Redis端口
REDIS_PASSWORD=redispassword           # Redis密码
REDIS_DB=0                             # Redis数据库
REDIS_MAX_CONNECTIONS=20               # Redis最大连接数

# ====================== JWT配置 ======================
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256                    # JWT算法
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30     # 访问令牌过期时间（分钟）
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7        # 刷新令牌过期时间（天）

# ====================== 租户配置 ======================
TENANT_ID_HEADER=X-Tenant-ID           # 租户ID请求头
DEFAULT_TENANT_ID=default              # 默认租户ID

# ====================== 文件上传配置 ======================
UPLOAD_MAX_SIZE=10485760               # 最大上传大小（10MB）
UPLOAD_ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx
UPLOAD_DIR=uploads                     # 上传目录

# ====================== 日志配置 ======================
LOG_LEVEL=INFO                         # 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_FILE=app.log                       # 日志文件路径（空则为控制台）
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ====================== 缓存配置 ======================
CACHE_DEFAULT_TIMEOUT=300              # 默认缓存超时（秒）
CACHE_KEY_PREFIX=coach_ai              # 缓存键前缀

# ====================== 安全配置 ======================
CORS_ORIGINS=*                         # CORS允许的源
RATE_LIMIT_ENABLED=true                # 启用速率限制
RATE_LIMIT_DEFAULT=100/hour            # 默认速率限制

# ====================== 中间件配置 ======================
MAX_REQUEST_BODY_SIZE=10485760         # 最大请求体大小（10MB）
RATE_LIMIT_WINDOW_SECONDS=3600         # 速率限制窗口（秒）
RATE_LIMIT_MAX_REQUESTS=100            # 最大请求数
XSRF_COOKIES=false                     # 启用XSRF Cookie
COOKIE_SECRET=cookie-secret-key-change-in-production

# ====================== 事件总线配置 ======================
EVENT_BUS_TYPE=memory                  # 事件总线类型: memory, redis, rabbitmq
EVENT_RETRY_ATTEMPTS=3                 # 事件重试次数
EVENT_RETRY_DELAY=1                    # 事件重试延迟（秒）

# ====================== 业务配置 ======================
# 成就系统
ACHIEVEMENT_UNLOCK_NOTIFICATION=true   # 成就解锁通知

# 任务系统
TASK_AUTO_ASSIGN=true                  # 任务自动分配
TASK_DEFAULT_PRIORITY=medium           # 任务默认优先级

# 运动系统
EXERCISE_SESSION_TIMEOUT=3600          # 运动会话超时（秒）

# ====================== 邮件配置（可选） ======================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-password
# EMAIL_FROM=noreply@coach-ai.com

# ====================== 第三方API配置（可选） ======================
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ====================== Docker部署配置 ======================
# 数据库root密码（仅用于Docker部署）
DB_ROOT_PASSWORD=rootpassword

# ====================== 监控配置（可选） ======================
# GRAFANA_PASSWORD=admin
# PROMETHEUS_PORT=9090

# 注意：
# 1. 生产环境必须修改所有包含"change-in-production"的密钥
# 2. 敏感信息（密码、API密钥）不应提交到版本控制系统
# 3. 生产环境建议使用环境变量或密钥管理服务