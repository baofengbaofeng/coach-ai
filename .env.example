# Django 设置
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 数据库设置 (开发环境使用 SQLite，生产环境使用 MySQL)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PASSWORD=coachaipassword
MYSQL_DATABASE=coachai
MYSQL_USER=coachai
MYSQL_HOST=localhost
MYSQL_PORT=3306

# 缓存设置 (开发环境使用虚拟缓存，生产环境使用 Redis)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS 设置
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 文件上传设置
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760  # 10MB
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760  # 10MB

# AI 服务设置
OCR_ENGINE=paddle  # paddle 或 easy
USE_GPU=False
WHISPER_MODEL_SIZE=base

# 日志设置
DJANGO_LOG_LEVEL=INFO

# 时区设置
TZ=Asia/Shanghai

# 安全设置 (生产环境需要设置为 True)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
