# 生产环境配置
# 警告：在生产环境中必须修改所有密码和密钥！

# 应用配置
APP_ENV=production
APP_DEBUG=false
APP_PORT=8000
APP_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# 数据库配置
DB_HOST=db
DB_PORT=3306
DB_NAME=coach_ai_prod
DB_USER=coach_ai_prod_user
DB_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Redis配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
REDIS_DB=0

# RabbitMQ配置
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=coach_ai
RABBITMQ_PASSWORD=CHANGE_THIS_TO_A_SECURE_PASSWORD
RABBITMQ_VHOST=/

# JWT配置
JWT_SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 多租户配置
TENANT_ID_HEADER=X-Tenant-ID
DEFAULT_TENANT_ID=default

# 日志配置
LOG_LEVEL=INFO

# CORS配置 - 限制为你的域名
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# 文件上传
UPLOAD_MAX_SIZE=52428800  # 50MB

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_AUTHENTICATED=1000/hour

# 安全头
SECURITY_HEADERS_ENABLED=true

# SSL配置（如果使用HTTPS）
SSL_ENABLED=false
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# 监控配置
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30

# 邮件配置（用于通知）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# 外部服务配置
# CDN_URL=https://cdn.yourdomain.com
# STATIC_URL=https://static.yourdomain.com